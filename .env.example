OPENAI_API_KEY=sk-...
CLAWTY_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
CLAWTY_WORKSPACE_ROOT=.
CLAWTY_TOOL_TIMEOUT_MS=120000
CLAWTY_MAX_TOOL_ITERATIONS=8
CLAWTY_INDEX_MAX_FILES=3000
CLAWTY_INDEX_MAX_FILE_SIZE_KB=512
CLAWTY_WATCH_INTERVAL_MS=2000
CLAWTY_WATCH_MAX_FILES=20000
CLAWTY_WATCH_MAX_BATCH_SIZE=300
CLAWTY_WATCH_DEBOUNCE_MS=500
CLAWTY_WATCH_HASH_SKIP_ENABLED=true
CLAWTY_WATCH_HASH_INIT_MAX_FILES=2000
CLAWTY_LSP_ENABLED=true
CLAWTY_LSP_TIMEOUT_MS=5000
CLAWTY_LSP_MAX_RESULTS=100
CLAWTY_LSP_TS_CMD=typescript-language-server --stdio
CLAWTY_EMBEDDING_ENABLED=false
CLAWTY_EMBEDDING_MODEL=text-embedding-3-small
CLAWTY_EMBEDDING_TOP_K=15
CLAWTY_EMBEDDING_WEIGHT=0.25
CLAWTY_EMBEDDING_TIMEOUT_MS=15000
# CLAWTY_EMBEDDING_API_KEY=sk-...
# CLAWTY_EMBEDDING_BASE_URL=https://api.openai.com/v1

OPENAI_API_KEY=sk-...
CLAWTY_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
CLAWTY_WORKSPACE_ROOT=.
CLAWTY_TOOL_TIMEOUT_MS=120000
CLAWTY_MAX_TOOL_ITERATIONS=8
CLAWTY_INDEX_MAX_FILES=3000
CLAWTY_INDEX_MAX_FILE_SIZE_KB=512
CLAWTY_INDEX_FRESHNESS_ENABLED=true
CLAWTY_INDEX_FRESHNESS_STALE_AFTER_MS=300000
CLAWTY_INDEX_FRESHNESS_WEIGHT=0.12
CLAWTY_INDEX_FRESHNESS_VECTOR_STALE_PENALTY=0.25
CLAWTY_INDEX_FRESHNESS_MAX_PATHS=200
CLAWTY_AGENT_INCREMENTAL_CONTEXT_ENABLED=true
CLAWTY_AGENT_INCREMENTAL_CONTEXT_MAX_PATHS=40
CLAWTY_AGENT_INCREMENTAL_CONTEXT_MAX_DIFF_CHARS=12000
CLAWTY_AGENT_INCREMENTAL_CONTEXT_TIMEOUT_MS=3000
CLAWTY_METRICS_ENABLED=true
CLAWTY_METRICS_PERSIST_HYBRID=true
CLAWTY_METRICS_PERSIST_WATCH=true
CLAWTY_METRICS_PERSIST_MEMORY=true
CLAWTY_METRICS_QUERY_PREVIEW_CHARS=160
CLAWTY_MEMORY_ENABLED=true
CLAWTY_MEMORY_MAX_INJECTED_ITEMS=5
CLAWTY_MEMORY_MAX_INJECTED_CHARS=2400
CLAWTY_MEMORY_AUTO_WRITE=true
CLAWTY_MEMORY_WRITE_GATE_ENABLED=true
CLAWTY_MEMORY_MIN_LESSON_CHARS=80
CLAWTY_MEMORY_DEDUPE_ENABLED=true
CLAWTY_MEMORY_QUARANTINE_THRESHOLD=3
CLAWTY_MEMORY_RANK_BM25_WEIGHT=0.34
CLAWTY_MEMORY_RANK_RECENCY_WEIGHT=0.16
CLAWTY_MEMORY_RANK_CONFIDENCE_WEIGHT=0.12
CLAWTY_MEMORY_RANK_SUCCESS_WEIGHT=0.12
CLAWTY_MEMORY_RANK_QUALITY_WEIGHT=0.14
CLAWTY_MEMORY_RANK_FEEDBACK_WEIGHT=0.12
CLAWTY_MEMORY_RANK_PROJECT_BOOST=1
CLAWTY_MEMORY_RANK_GLOBAL_BOOST=0.35
CLAWTY_MEMORY_RANK_NEGATIVE_PENALTY_PER_DOWNVOTE=0.06
CLAWTY_MEMORY_RANK_NEGATIVE_PENALTY_CAP=0.3
CLAWTY_MEMORY_RANK_RECENT_NEGATIVE_PENALTY=0.18
CLAWTY_MEMORY_RANK_RECENT_NEGATIVE_RECENCY_THRESHOLD=0.55
CLAWTY_MEMORY_SCOPE=project+global
CLAWTY_WATCH_INTERVAL_MS=2000
CLAWTY_WATCH_MAX_FILES=20000
CLAWTY_WATCH_MAX_BATCH_SIZE=300
CLAWTY_WATCH_DEBOUNCE_MS=500
CLAWTY_WATCH_HASH_SKIP_ENABLED=true
CLAWTY_WATCH_HASH_INIT_MAX_FILES=2000
CLAWTY_WATCH_INCLUDE_VECTOR=false
CLAWTY_WATCH_VECTOR_LAYER=delta
CLAWTY_LSP_ENABLED=true
CLAWTY_LSP_TIMEOUT_MS=5000
CLAWTY_LSP_MAX_RESULTS=100
CLAWTY_LSP_TS_CMD=typescript-language-server --stdio
CLAWTY_EMBEDDING_ENABLED=false
CLAWTY_EMBEDDING_MODEL=text-embedding-3-small
CLAWTY_EMBEDDING_TOP_K=15
CLAWTY_EMBEDDING_WEIGHT=0.25
CLAWTY_EMBEDDING_TIMEOUT_MS=15000

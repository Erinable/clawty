{
  "openai": {
    "apiKey": "sk-...",
    "baseUrl": "https://api.openai.com/v1"
  },
  "model": "gpt-4.1-mini",
  "workspaceRoot": ".",
  "tools": {
    "timeoutMs": 120000,
    "maxIterations": 8
  },
  "index": {
    "maxFiles": 3000,
    "maxFileSizeKb": 512,
    "freshnessEnabled": true,
    "freshnessStaleAfterMs": 300000,
    "freshnessWeight": 0.12,
    "freshnessVectorStalePenalty": 0.25,
    "freshnessMaxPaths": 200
  },
  "lsp": {
    "enabled": true,
    "timeoutMs": 5000,
    "maxResults": 100,
    "tsCommand": "typescript-language-server --stdio"
  },
  "embedding": {
    "enabled": false,
    "apiKey": "sk-...",
    "baseUrl": "https://api.openai.com/v1",
    "model": "text-embedding-3-small",
    "topK": 15,
    "weight": 0.25,
    "timeoutMs": 15000
  },
  "agentContext": {
    "incrementalContextEnabled": true,
    "incrementalContextMaxPaths": 40,
    "incrementalContextMaxDiffChars": 12000,
    "incrementalContextTimeoutMs": 3000
  },
  "metrics": {
    "enabled": true,
    "persistHybrid": true,
    "persistWatch": true,
    "persistMemory": true,
    "queryPreviewChars": 160
  },
  "onlineTuner": {
    "enabled": false,
    "mode": "off",
    "dbPath": ".clawty/tuner.db",
    "epsilon": 0.08,
    "globalPriorWeight": 0.35,
    "localWarmupSamples": 50,
    "minConstraintSamples": 30,
    "maxDegradeRate": 0.1,
    "maxTimeoutRate": 0.08,
    "maxNetworkRate": 0.05,
    "successRewardThreshold": 0.35
  },
  "memory": {
    "enabled": true,
    "maxInjectedItems": 5,
    "maxInjectedChars": 2400,
    "autoWrite": true,
    "writeGateEnabled": true,
    "minLessonChars": 80,
    "dedupeEnabled": true,
    "quarantineThreshold": 3,
    "ranking": {
      "bm25Weight": 0.34,
      "recencyWeight": 0.16,
      "confidenceWeight": 0.12,
      "successRateWeight": 0.12,
      "qualityWeight": 0.14,
      "feedbackWeight": 0.12,
      "projectBoost": 1,
      "globalBoost": 0.35,
      "negativePenaltyPerDownvote": 0.06,
      "negativePenaltyCap": 0.3,
      "recentNegativePenalty": 0.18,
      "recentNegativeRecencyThreshold": 0.55
    },
    "scope": "project+global"
  }
}

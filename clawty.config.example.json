{
  "openai": {
    "apiKey": "sk-...",
    "baseUrl": "https://api.openai.com/v1"
  },
  "model": "gpt-4.1-mini",
  "workspaceRoot": ".",
  "tools": {
    "timeoutMs": 120000,
    "maxIterations": 8
  },
  "index": {
    "maxFiles": 3000,
    "maxFileSizeKb": 512,
    "freshnessEnabled": true,
    "freshnessStaleAfterMs": 300000,
    "freshnessWeight": 0.12,
    "freshnessVectorStalePenalty": 0.25,
    "freshnessMaxPaths": 200
  },
  "lsp": {
    "enabled": true,
    "timeoutMs": 5000,
    "maxResults": 100,
    "tsCommand": "typescript-language-server --stdio"
  },
  "embedding": {
    "enabled": false,
    "apiKey": "sk-...",
    "baseUrl": "https://api.openai.com/v1",
    "model": "text-embedding-3-small",
    "topK": 15,
    "weight": 0.25,
    "timeoutMs": 15000
  },
  "agentContext": {
    "incrementalContextEnabled": true,
    "incrementalContextMaxPaths": 40,
    "incrementalContextMaxDiffChars": 12000,
    "incrementalContextTimeoutMs": 3000
  },
  "metrics": {
    "enabled": true,
    "persistHybrid": true,
    "persistWatch": true,
    "queryPreviewChars": 160
  }
}

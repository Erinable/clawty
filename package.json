{
  "name": "clawty",
  "version": "0.1.0",
  "description": "MVP CLI AI coding assistant",
  "private": true,
  "type": "module",
  "bin": {
    "clawty": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "chat": "node src/index.js chat",
    "run": "node src/index.js run",
    "help": "node src/index.js --help",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage",
    "coverage:check": "node scripts/check-coverage-thresholds.mjs",
    "verify:tree-sitter": "node --input-type=module -e \"await import('tree-sitter'); await import('tree-sitter-javascript'); await import('tree-sitter-python'); await import('tree-sitter-go'); console.log('tree-sitter runtime ready')\"",
    "bench:index": "node tests/bench/code-index.bench.js",
    "bench:index:check": "node tests/bench/code-index.bench.js --check-baseline --threshold=20",
    "bench:index:baseline": "node tests/bench/code-index.bench.js --write-baseline",
    "bench:semantic": "node tests/bench/code-index-semantic.bench.js",
    "bench:semantic:check": "node tests/bench/code-index-semantic.bench.js --check-baseline --threshold=5",
    "bench:semantic:baseline": "node tests/bench/code-index-semantic.bench.js --write-baseline",
    "bench:graph": "node tests/bench/semantic-graph.bench.js",
    "bench:graph:check": "node tests/bench/semantic-graph.bench.js --check-baseline --threshold=5",
    "bench:graph:baseline": "node tests/bench/semantic-graph.bench.js --write-baseline",
    "bench:graph:refresh": "node tests/bench/semantic-graph-refresh.bench.js",
    "bench:graph:refresh:check": "node tests/bench/semantic-graph-refresh.bench.js --check-baseline --threshold=2",
    "bench:graph:refresh:baseline": "node tests/bench/semantic-graph-refresh.bench.js --write-baseline",
    "precise:check": "node scripts/check-precise-index.mjs --path artifacts/scip.normalized.json --allow-missing",
    "precise:check:fixture": "node scripts/check-precise-index.mjs --path tests/fixtures/precise/scip.normalized.json",
    "precise:import": "node scripts/import-precise-index.mjs --path artifacts/scip.normalized.json --mode replace --source scip"
  },
  "dependencies": {
    "tree-sitter": "0.25.0",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0"
  }
}
